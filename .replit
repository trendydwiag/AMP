modules = ["postgresql-16", "python-base-3.13", "nodejs-24"]
[nix]
channel = "stable-25_05"
packages = ["postgresql"]

[agent]
expertMode = true

[userenv]

[userenv.shared]
DJANGO_ALLOWED_HOSTS = "*"
DJANGO_DEBUG = "True"
DJANGO_SETTINGS_MODULE = "config.settings.development"
LANGUAGE_CODE = "id"
LOG_LEVEL = "INFO"
TIME_ZONE = "Asia/Jakarta"
USE_S3 = "False"
